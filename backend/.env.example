# WalletSecure Backend Environment Configuration Template
# Copy this file to .env and fill in your actual production values

# --- Database ---
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
DB_NAME=walletsecure

# --- Security ---
# Secret key for signing JWT access tokens (Generate a strong random string)
JWT_SECRET=your_super_secret_jwt_signing_key_here

# --- Web3 / Blockchain ---
# Alchemy API key for Ethereum mainnet RPC access
ALCHEMY_API_KEY=your_alchemy_api_key_here

# --- Payments ---
# Stripe Secret API Key (sk_test_... or sk_live_...)
STRIPE_API_KEY=your_stripe_secret_key_here
# Stripe Webhook Secret for verifying incoming payment events (whsec_...)
WEBHOOK_SECRET=your_stripe_webhook_secret_here

# --- Optional External Integrations ---
# SendGrid API Key for email alerts
SENDGRID_API_KEY=
SENDER_EMAIL=noreply@walletsecure.com
# Telegram Bot Token for chat alerts
TELEGRAM_BOT_TOKEN=

# --- Server Settings ---
# Allowed CORS origins (comma-separated, use * for all)
CORS_ORIGINS=http://localhost:3000,https://walletsecure.preview.emergentagent.com

# --- Admin ---
# Comma-separated wallet addresses that get admin privileges
ADMIN_WALLETS=0xYourAdminWalletAddressHere
